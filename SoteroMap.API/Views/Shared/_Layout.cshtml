<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SoteroMap Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        .sidebar { min-height: 100vh; background: #1e293b; }
        .sidebar .nav-link { color: #94a3b8; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: #334155; border-radius: 6px; }
        .sidebar-brand { color: #38bdf8 !important; font-weight: 700; }
        .badge-active { background: #22c55e; }
        .badge-maintenance { background: #f59e0b; }
        .badge-inactive { background: #ef4444; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 col-lg-2 d-md-block sidebar py-3 px-3">
                <a class="navbar-brand sidebar-brand d-block mb-4 fs-5" href="/admin">
                    <i class="bi bi-map-fill me-2"></i>SoteroMap
                </a>
                <div class="bg-dark bg-opacity-25 rounded-3 p-3 mb-4 text-white">
                    <div class="small text-uppercase text-secondary mb-1">Sesion</div>
                    <div class="fw-semibold">@(User.Identity?.Name ?? "Sin sesion")</div>
                    <div class="small text-info">Rol: @(User.IsInRole(SoteroMap.API.Models.AppRoles.Admin) ? "admin" : "user")</div>
                </div>
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" href="/admin">
                            <i class="bi bi-speedometer2 me-2"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Location") == true ? "active" : "")" href="/admin/locations">
                            <i class="bi bi-geo-alt me-2"></i>Ubicaciones
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @((ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Inventory") == true || ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Equipment") == true) ? "active" : "")" href="/admin/inventory">
                            <i class="bi bi-pc-display me-2"></i>Inventario
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Activity" ? "active" : "")" href="/admin/activity">
                            <i class="bi bi-clock-history me-2"></i>Actividad
                        </a>
                    </li>
                    <li class="nav-item mt-3">
                        <a class="nav-link text-info" href="/swagger" target="_blank">
                            <i class="bi bi-code-slash me-2"></i>API Docs
                        </a>
                    </li>
                </ul>
                <form method="post" action="/Auth/Logout" class="mt-4">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light w-100">
                        <i class="bi bi-box-arrow-left me-2"></i>Cerrar sesion
                    </button>
                </form>
            </nav>

            <main class="col-md-10 col-lg-10 ms-sm-auto px-md-4 py-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
