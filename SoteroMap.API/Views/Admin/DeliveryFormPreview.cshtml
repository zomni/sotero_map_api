@model SoteroMap.API.ViewModels.DeliveryFormPreviewViewModel
@{
    ViewData["Title"] = "Vista previa PDF";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Vista previa del formulario</h2>
        <div class="text-muted">Revisa el PDF, imprímelo o guárdalo desde el visor del navegador.</div>
    </div>
    <a href="/admin/delivery-form" class="btn btn-secondary shadow-sm fw-semibold px-3">
        <i class="bi bi-arrow-left me-1"></i> Volver al formulario
    </a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="/admin/delivery-form/preview/@Model.PreviewId/file" target="_blank" class="btn btn-primary">
                <i class="bi bi-box-arrow-up-right me-1"></i> Abrir PDF
            </a>
            <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('delivery-pdf-frame')?.contentWindow?.print();">
                <i class="bi bi-printer me-1"></i> Imprimir
            </button>
            <a href="/admin/delivery-form" class="btn btn-outline-primary">
                <i class="bi bi-plus-lg me-1"></i> Crear otro formulario
            </a>
        </div>

        <div class="border rounded overflow-hidden" style="height: 82vh; min-height: 700px;">
            <iframe id="delivery-pdf-frame"
                    src="/admin/delivery-form/preview/@Model.PreviewId/file"
                    title="Vista previa PDF del formulario"
                    style="width: 100%; height: 100%; border: 0;"></iframe>
        </div>
    </div>
</div>
