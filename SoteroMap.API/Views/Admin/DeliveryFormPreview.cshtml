@model SoteroMap.API.ViewModels.DeliveryFormPreviewViewModel
@{
    ViewData["Title"] = "Vista previa PDF";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Vista previa del formulario</h2>
        <div class="text-muted">Revisa el PDF, imprímelo o guárdalo desde el visor del navegador.</div>
    </div>
    <a href="/admin/delivery-form" class="btn btn-secondary shadow-sm fw-semibold px-3">
        <i class="bi bi-arrow-left me-1"></i> Volver al formulario
    </a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="/admin/delivery-form/preview/@Model.PreviewId/file" target="_blank" class="btn btn-primary">
                <i class="bi bi-box-arrow-up-right me-1"></i> Abrir PDF
            </a>
            <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('delivery-pdf-frame')?.contentWindow?.print();">
                <i class="bi bi-printer me-1"></i> Imprimir
            </button>
            <a href="/admin/delivery-form" class="btn btn-outline-primary">
                <i class="bi bi-plus-lg me-1"></i> Crear otro formulario
            </a>
            @if (Model.CreatedInventoryItemId.HasValue)
            {
                <a href="/admin/editinventoryitem/@Model.CreatedInventoryItemId.Value" class="btn btn-success">
                    <i class="bi bi-box-seam me-1"></i> Ver equipo creado
                </a>
            }
        </div>

        @if (User.IsInRole(SoteroMap.API.Models.AppRoles.Admin))
        {
            <div class="card border-0 bg-light-subtle mb-3">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <h5 class="fw-semibold mb-1">Agregar equipo al inventario</h5>
                            <div class="text-muted small">
                                Usa los datos del formulario para crear el equipo en el inventario y, si quieres, dejarlo asignado de inmediato a un edificio.
                            </div>
                        </div>
                        @if (Model.SourceForm is not null)
                        {
                            <div class="text-muted small text-md-end">
                                <div><strong>S/N:</strong> @(string.IsNullOrWhiteSpace(Model.SourceForm.SerialNumber) ? "-" : Model.SourceForm.SerialNumber)</div>
                                <div><strong>Usuario:</strong> @(string.IsNullOrWhiteSpace(Model.SourceForm.ResponsibleUser) ? "-" : Model.SourceForm.ResponsibleUser)</div>
                            </div>
                        }
                    </div>

                    @if (Model.SourceForm is null)
                    {
                        <div class="alert alert-warning mb-0">
                            Esta vista previa no conserva los datos necesarios para crear el equipo. Genera el formulario nuevamente si quieres agregarlo al inventario desde aqui.
                        </div>
                    }
                    else if (Model.CreatedInventoryItemId.HasValue)
                    {
                        <div class="alert alert-success mb-0 d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <span>Este formulario ya genero el equipo en inventario.</span>
                            <a href="/admin/editinventoryitem/@Model.CreatedInventoryItemId.Value" class="btn btn-success btn-sm">
                                <i class="bi bi-pencil-square me-1"></i> Editar equipo
                            </a>
                        </div>
                    }
                    else
                    {
                        <form method="post" action="/admin/delivery-form/preview/@Model.PreviewId/inventory" class="row g-3 align-items-end">
                            @Html.AntiForgeryToken()
                            <div class="col-lg-8">
                                <label for="assignedBuildingExternalId" class="form-label">Edificio asignado inicial</label>
                                <select id="assignedBuildingExternalId" name="assignedBuildingExternalId" class="form-select">
                                    <option value="">Dejar sin asignar por ahora</option>
                                    @foreach (var building in Model.Buildings)
                                    {
                                        if (string.Equals(Model.AssignedBuildingExternalId, building.ExternalId, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@building.ExternalId" selected>@building.EffectiveDisplayName (@building.ExternalId)</option>
                                        }
                                        else
                                        {
                                            <option value="@building.ExternalId">@building.EffectiveDisplayName (@building.ExternalId)</option>
                                        }
                                    }
                                </select>
                                <div class="form-text">Solo el edificio se asigna aqui. La sala y el piso los puedes completar despues desde inventario si hace falta.</div>
                            </div>
                            <div class="col-lg-4 d-grid">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-box-arrow-in-down me-1"></i> Agregar al inventario
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        }

        <div class="border rounded overflow-hidden" style="height: 82vh; min-height: 700px;">
            <iframe id="delivery-pdf-frame"
                    src="/admin/delivery-form/preview/@Model.PreviewId/file"
                    title="Vista previa PDF del formulario"
                    style="width: 100%; height: 100%; border: 0;"></iframe>
        </div>
    </div>
</div>
