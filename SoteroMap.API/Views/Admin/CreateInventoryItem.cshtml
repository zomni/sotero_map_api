@model SoteroMap.API.ViewModels.CreateInventoryItemViewModel
@{
    ViewData["Title"] = "Agregar equipo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Agregar equipo al inventario</h2>
        <div class="text-muted">Alta manual disponible solo para administradores.</div>
    </div>
    <a href="/admin/inventory" class="btn btn-secondary shadow-sm fw-semibold px-3">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <form method="post" action="/admin/inventory/create" class="row g-4">
            @Html.AntiForgeryToken()

            <div class="col-lg-7">
                <div class="card border-0 bg-light-subtle h-100">
                    <div class="card-body">
                        <h5 class="fw-semibold mb-3">Datos principales</h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Form.SerialNumber" class="form-label">S/N serial number</label>
                                <input asp-for="Form.SerialNumber" class="form-control font-monospace" placeholder="Ej: SMJ0LBD3N" />
                                <span asp-validation-for="Form.SerialNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.ItemNumber" class="form-label">Numero item</label>
                                <input asp-for="Form.ItemNumber" class="form-control" placeholder="Si lo dejas vacio se genera automaticamente" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Form.Description" class="form-label">Descripcion</label>
                                <input asp-for="Form.Description" class="form-control" placeholder="Ej: OPTIPLEX ALL-IN-ONE PLUS 7420" />
                                <span asp-validation-for="Form.Description" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Form.InferredCategory" class="form-label">Categoria</label>
                                <select asp-for="Form.InferredCategory" class="form-select">
                                    @foreach (var category in Model.Categories)
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </select>
                                <span asp-validation-for="Form.InferredCategory" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Form.InferredStatus" class="form-label">Estado</label>
                                <select asp-for="Form.InferredStatus" class="form-select">
                                    @foreach (var status in Model.Statuses)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                                <span asp-validation-for="Form.InferredStatus" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Form.Lot" class="form-label">Lote</label>
                                <input asp-for="Form.Lot" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.ResponsibleUser" class="form-label">Usuario responsable</label>
                                <input asp-for="Form.ResponsibleUser" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.Email" class="form-label">Email</label>
                                <input asp-for="Form.Email" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.UnitOrDepartment" class="form-label">Unidad o depto</label>
                                <input asp-for="Form.UnitOrDepartment" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.OrganizationalUnit" class="form-label">Unidad organizativa</label>
                                <input asp-for="Form.OrganizationalUnit" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.JobTitle" class="form-label">Cargo</label>
                                <input asp-for="Form.JobTitle" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Form.Installer" class="form-label">Tecnico / referencia</label>
                                <input asp-for="Form.Installer" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Form.IpAddress" class="form-label">IP</label>
                                <input asp-for="Form.IpAddress" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Form.MacAddress" class="form-label">MAC</label>
                                <input asp-for="Form.MacAddress" class="form-control font-monospace" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Form.AnnexPhone" class="form-label">Anexo / telefono</label>
                                <input asp-for="Form.AnnexPhone" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Form.Observation" class="form-label">Observacion</label>
                                <textarea asp-for="Form.Observation" class="form-control" rows="3" placeholder="Notas generales del equipo..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 bg-light-subtle h-100">
                    <div class="card-body">
                        <h5 class="fw-semibold mb-3">Asignacion inicial</h5>
                        <div class="text-muted small mb-3">Si dejas el edificio vacio, el equipo quedara pendiente para asignarlo despues. Si eliges una sala, el piso quedara bloqueado segun esa sala.</div>

                        <div class="mb-3">
                            <label asp-for="Form.AssignedBuildingExternalId" class="form-label">Edificio</label>
                            <select asp-for="Form.AssignedBuildingExternalId" class="form-select" id="assignedBuildingExternalId">
                                <option value="">Sin asignar</option>
                                @foreach (var building in Model.Buildings)
                                {
                                    <option value="@building.ExternalId">@building.EffectiveDisplayName (@building.ExternalId)</option>
                                }
                            </select>
                            <span asp-validation-for="Form.AssignedBuildingExternalId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.AssignedRoomExternalId" class="form-label">Sala</label>
                            <select asp-for="Form.AssignedRoomExternalId" class="form-select" id="assignedRoomExternalId">
                                <option value="">Sin asignar</option>
                                @foreach (var room in Model.Rooms)
                                {
                                    <option value="@room.ExternalId" data-building="@room.BuildingExternalId" data-floor="@room.EffectiveFloor">
                                        @room.EffectiveName (@room.BuildingExternalId / piso @room.EffectiveFloor)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Form.AssignedRoomExternalId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.AssignedFloor" class="form-label">Piso</label>
                            <input asp-for="Form.AssignedFloor" type="number" class="form-control" id="assignedFloor" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.AssignmentNotes" class="form-label">Notas de asignacion</label>
                            <textarea asp-for="Form.AssignmentNotes" class="form-control" rows="4" placeholder="Ej: equipo nuevo pendiente de confirmar sala exacta"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.TicketMda" class="form-label">Ticket MDA</label>
                            <input asp-for="Form.TicketMda" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Crear equipo
                </button>
                <a href="/admin/inventory" class="btn btn-secondary shadow-sm fw-semibold px-3">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const buildingSelect = document.getElementById("assignedBuildingExternalId");
        const roomSelect = document.getElementById("assignedRoomExternalId");
        const floorInput = document.getElementById("assignedFloor");

        function syncFloorState() {
            const hasRoom = roomSelect.value !== "";
            floorInput.readOnly = hasRoom;
            floorInput.classList.toggle("bg-light", hasRoom);

            if (hasRoom) {
                const selectedOption = roomSelect.options[roomSelect.selectedIndex];
                const roomFloor = selectedOption ? selectedOption.getAttribute("data-floor") : null;
                if (roomFloor) {
                    floorInput.value = roomFloor;
                }
            }
        }

        function syncRoomOptions() {
            const selectedBuilding = buildingSelect.value;

            Array.from(roomSelect.options).forEach((option, index) => {
                if (index === 0) {
                    option.hidden = false;
                    return;
                }

                const optionBuilding = option.getAttribute("data-building");
                option.hidden = selectedBuilding !== "" && optionBuilding !== selectedBuilding;
            });

            const selectedOption = roomSelect.options[roomSelect.selectedIndex];
            if (selectedOption && selectedOption.hidden) {
                roomSelect.value = "";
            }

            syncFloorState();
        }

        buildingSelect.addEventListener("change", syncRoomOptions);
        roomSelect.addEventListener("change", function () {
            const selectedOption = roomSelect.options[roomSelect.selectedIndex];
            const roomBuilding = selectedOption ? selectedOption.getAttribute("data-building") : null;

            if (roomBuilding) {
                buildingSelect.value = roomBuilding;
            }

            syncRoomOptions();
        });

        syncRoomOptions();
    })();
</script>
}