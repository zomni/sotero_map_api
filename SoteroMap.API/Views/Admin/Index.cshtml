@model SoteroMap.API.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = User.IsInRole(SoteroMap.API.Models.AppRoles.Admin);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Dashboard</h2>
    <span class="text-muted">Inventario importado y asignacion manual</span>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-buildings text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Edificios sincronizados</div>
                        <div class="fs-3 fw-bold">@Model.SyncedBuildings</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-pc-display text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Equipos importados</div>
                        <div class="fs-3 fw-bold">@Model.TotalImportedItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-check2-circle text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Asignados manualmente</div>
                        <div class="fs-3 fw-bold">@Model.AssignedItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Pendientes</div>
                        <div class="fs-3 fw-bold">@Model.PendingAssignmentItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Accesos rapidos</div>
            <div class="card-body d-flex gap-3 flex-wrap">
                <a href="/admin/inventory" class="btn btn-primary">
                    <i class="bi bi-list-ul me-1"></i> Revisar inventario
                </a>
                <a href="/api/inventory-import/status" class="btn btn-outline-success" target="_blank">
                    <i class="bi bi-file-earmark-arrow-down me-1"></i> Estado importacion
                </a>
                <a href="/api/inventory-import/items" class="btn btn-outline-secondary" target="_blank">
                    <i class="bi bi-braces me-1"></i> Ver JSON
                </a>
                <a href="/swagger" class="btn btn-outline-dark" target="_blank">
                    <i class="bi bi-box-arrow-up-right me-1"></i> Swagger
                </a>
                <a href="/admin/activity" class="btn btn-outline-primary">
                    <i class="bi bi-clock-history me-1"></i> Ver actividad
                </a>
                <a href="@Model.FrontendMapUrl" class="btn btn-outline-info js-map-link" target="sotero-map">
                    <i class="bi bi-map me-1"></i> Ir al mapa
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Resumen operativo</div>
            <div class="card-body">
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span class="text-muted">Salas sincronizadas</span>
                    <strong>@Model.SyncedRooms</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span class="text-muted">Con sugerencia automatica</span>
                    <strong>@Model.SuggestedItems</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                    <span class="text-muted">Marcados como robados</span>
                    <strong>@Model.StolenItems</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Categorias detectadas</span>
                    <strong>@Model.DistinctImportedCategories</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isAdmin)
{
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Base de datos</div>
                <div class="card-body">
                    <div class="row g-4 align-items-start">
                        <div class="col-lg-5">
                            <div class="small text-muted mb-2">Archivo actual</div>
                            <div class="fw-semibold">@Model.DatabaseFileName</div>
                            <div class="text-muted small">Tamano: @(Model.DatabaseFileSizeBytes > 0 ? $"{Model.DatabaseFileSizeBytes / 1024.0 / 1024.0:F2} MB" : "Sin datos")</div>
                            <div class="text-muted small">Ultima modificacion: @(Model.DatabaseLastWriteUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Sin datos")</div>
                            <a href="/admin/database/download" class="btn btn-outline-primary mt-3">
                                <i class="bi bi-download me-1"></i> Descargar DB
                            </a>
                        </div>
                        <div class="col-lg-7">
                            <div class="small text-muted mb-2">Restaurar base de datos</div>
                            <form id="databaseUploadForm" method="post" action="/admin/database/upload" enctype="multipart/form-data" class="row g-3">
                                @Html.AntiForgeryToken()
                                <div class="col-md-8">
                                    <input id="databaseFileInput" type="file" name="databaseFile" class="form-control" accept=".db,.sqlite,.sqlite3" required />
                                    <div class="form-text">Se crea un respaldo automatico antes de reemplazar la base actual.</div>
                                </div>
                                <div class="col-md-4 d-grid">
                                    <button id="databaseUploadButton" type="submit" class="btn btn-secondary" disabled>
                                        <i class="bi bi-upload me-1"></i> Subir DB
                                    </button>
                                </div>
                            </form>

                            <div class="mt-4">
                                <div class="small text-muted mb-2">Respaldos disponibles</div>
                                @if (Model.DatabaseBackups.Count == 0)
                                {
                                    <div class="text-muted small">Todavia no hay respaldos guardados.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Archivo</th>
                                                    <th>Fecha</th>
                                                    <th>Tamano</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var backup in Model.DatabaseBackups)
                                                {
                                                    <tr>
                                                        <td class="small fw-semibold">@backup.FileName</td>
                                                        <td class="small">@backup.LastWriteUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                                        <td class="small">@($"{backup.SizeBytes / 1024.0 / 1024.0:F2} MB")</td>
                                                        <td class="text-end">
                                                            <div class="d-flex gap-2 justify-content-end">
                                                                <a href="/admin/database/backups/@backup.FileName" class="btn btn-sm btn-outline-secondary">
                                                                    Descargar
                                                                </a>
                                                                <form method="post" action="/admin/database/backups/@backup.FileName/restore" onsubmit="return confirm('Se restaurara este respaldo y se reemplazara la base actual. ¿Continuar?');">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                                                        Restaurar
                                                                    </button>
                                                                </form>
                                                                <form method="post" action="/admin/database/backups/@backup.FileName/delete" onsubmit="return confirm('Se eliminara este respaldo. Esta accion no se puede deshacer. ¿Continuar?');">
                                                                    @Html.AntiForgeryToken()
                                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                        Eliminar
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4 mt-1">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                <span>Ultimos cambios registrados</span>
                <a href="/admin/activity" class="btn btn-sm btn-outline-secondary">Ver completo</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Usuario</th>
                                <th>Edificio</th>
                                <th>Resumen</th>
                                <th>Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentActivity.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Todavia no hay cambios auditados.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var entry in Model.RecentActivity)
                                {
                                    <tr>
                                        <td class="small text-nowrap">@entry.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="small">@entry.ChangedByUsername</td>
                                        <td class="small">@entry.BuildingExternalId</td>
                                        <td>@entry.Summary</td>
                                        <td class="small text-muted">@entry.Details</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const fileInput = document.getElementById("databaseFileInput");
            const uploadButton = document.getElementById("databaseUploadButton");
            const uploadForm = document.getElementById("databaseUploadForm");

            if (!fileInput || !uploadButton || !uploadForm) {
                return;
            }

            let hasPendingDatabaseFile = false;

            const updateUploadState = () => {
                hasPendingDatabaseFile = Boolean(fileInput.files && fileInput.files.length > 0);
                uploadButton.disabled = !hasPendingDatabaseFile;
                uploadButton.classList.toggle("btn-secondary", !hasPendingDatabaseFile);
                uploadButton.classList.toggle("btn-warning", hasPendingDatabaseFile);
            };

            const confirmPendingDatabaseNavigation = () => {
                if (!hasPendingDatabaseFile) {
                    return true;
                }

                return window.confirm("Tienes un archivo DB pendiente por subir. ¿Deseas continuar sin subirlo?");
            };

            fileInput.addEventListener("change", updateUploadState);
            uploadForm.addEventListener("submit", () => {
                hasPendingDatabaseFile = false;
            });

            document.addEventListener("click", (event) => {
                const anchor = event.target.closest("a[href]");
                if (!anchor) {
                    return;
                }

                const href = anchor.getAttribute("href");
                if (!href || href.startsWith("#") || href.startsWith("javascript:")) {
                    return;
                }

                const destination = new URL(anchor.href, window.location.href);
                const current = new URL(window.location.href);

                if (destination.href === current.href) {
                    return;
                }

                if (!confirmPendingDatabaseNavigation()) {
                    event.preventDefault();
                    event.stopPropagation();
                    return;
                }

                hasPendingDatabaseFile = false;
            }, true);

            document.addEventListener("submit", (event) => {
                const form = event.target;
                if (!(form instanceof HTMLFormElement) || form === uploadForm) {
                    return;
                }

                if (!confirmPendingDatabaseNavigation()) {
                    event.preventDefault();
                    event.stopPropagation();
                    return;
                }

                hasPendingDatabaseFile = false;
            }, true);

            window.addEventListener("beforeunload", (event) => {
                if (!hasPendingDatabaseFile) {
                    return;
                }

                event.preventDefault();
                event.returnValue = "";
            });

            document.querySelectorAll(".js-map-link").forEach((link) => {
                link.addEventListener("click", (event) => {
                    event.preventDefault();

                    if (!confirmPendingDatabaseNavigation()) {
                        return;
                    }

                    hasPendingDatabaseFile = false;
                    window.open(link.href, "sotero-map");
                });
            });

            updateUploadState();
        })();
    </script>
}

<div class="row g-4 mt-1">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Categorias importadas</div>
            <div class="card-body">
                @if (Model.CategoryBreakdown.Count == 0)
                {
                    <div class="text-muted">Todavia no hay equipos importados.</div>
                }
                else
                {
                    @foreach (var category in Model.CategoryBreakdown)
                    {
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <span>@category.Category</span>
                            <span class="fw-semibold">@category.Count</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Ultimos registros importados</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Equipo</th>
                            <th>Responsable</th>
                            <th>Unidad</th>
                            <th>Asignacion</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentItems)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.Description</div>
                                    <div class="small text-muted">@item.InferredStatus</div>
                                </td>
                                <td class="small">@item.ResponsibleUser</td>
                                <td class="small">@item.UnitOrDepartment</td>
                                <td class="small">
                                    @(string.IsNullOrWhiteSpace(item.AssignedBuildingExternalId) ? "Pendiente" : item.AssignedBuildingExternalId)
                                </td>
                                <td class="text-end">
                                    <a href="/admin/editinventoryitem/@item.Id" class="btn btn-sm btn-outline-primary">
                                        @(isAdmin ? "Editar" : "Ver")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
