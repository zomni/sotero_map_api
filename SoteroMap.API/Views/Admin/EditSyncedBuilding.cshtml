@using System.Text.Json
@model SoteroMap.API.ViewModels.EditSyncedBuildingViewModel
@{
    ViewData["Title"] = "Editar edificio sincronizado";
    Layout = "~/Views/Shared/_Layout.cshtml";

    static string FloorsToCsv(string floorsJson)
    {
        if (string.IsNullOrWhiteSpace(floorsJson))
            return string.Empty;

        try
        {
            var floors = JsonSerializer.Deserialize<List<int>>(floorsJson) ?? [];
            return string.Join(", ", floors);
        }
        catch
        {
            return string.Empty;
        }
    }

    var building = Model.Building;
    var sourceFloorsCsv = FloorsToCsv(building.FloorsJson);
    var overrideFloorsCsv = FloorsToCsv(building.ManualFloorsJson);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Editar edificio sincronizado</h2>
        <div class="text-muted">Los overrides manuales sobreviven cuando vuelvas a sincronizar desde el frontend.</div>
    </div>
    <a href="/admin/locations" class="btn btn-secondary shadow-sm fw-semibold px-3">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-semibold mb-3">Override manual</h5>
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre del edificio</label>
                        <input name="manualDisplayName"
                               class="form-control"
                               value="@building.ManualDisplayName"
                               placeholder="@building.DisplayName" />
                        <div class="form-text">Dejalo vacio para usar el nombre original sincronizado.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Campus</label>
                        <input name="manualCampus"
                               class="form-control"
                               value="@building.ManualCampus"
                               placeholder="@building.Campus" />
                        <div class="form-text">Ejemplo: sotero, casr u otro campus que necesites corregir.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Pisos</label>
                        <input name="manualFloorsCsv"
                               class="form-control"
                               value="@overrideFloorsCsv"
                               placeholder="@sourceFloorsCsv" />
                        <div class="form-text">Ingresa pisos separados por coma, por ejemplo: 0, 1, 2.</div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Guardar override
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-semibold mb-3">Valores actuales</h5>
                <div class="mb-2"><span class="text-muted">ID:</span> <span class="fw-semibold">@building.ExternalId</span></div>
                <div class="mb-2"><span class="text-muted">Nombre fuente:</span> @building.DisplayName</div>
                <div class="mb-2"><span class="text-muted">Campus fuente:</span> @building.Campus</div>
                <div class="mb-2"><span class="text-muted">Pisos fuente:</span> @(string.IsNullOrWhiteSpace(sourceFloorsCsv) ? "-" : sourceFloorsCsv)</div>
                <hr />
                <div class="mb-2"><span class="text-muted">Nombre efectivo:</span> <span class="fw-semibold">@building.EffectiveDisplayName</span></div>
                <div class="mb-2"><span class="text-muted">Campus efectivo:</span> @building.EffectiveCampus</div>
                <div class="mb-2"><span class="text-muted">Pisos efectivos:</span> @(string.IsNullOrWhiteSpace(FloorsToCsv(building.EffectiveFloorsJson)) ? "-" : FloorsToCsv(building.EffectiveFloorsJson))</div>
                <div class="mb-2"><span class="text-muted">Area responsable:</span> @building.ResponsibleArea</div>
                <div class="mb-0"><span class="text-muted">Ultima sincronizacion:</span> @building.SyncedAtUtc.ToLocalTime().ToString("g")</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="fw-semibold mb-1">Salas del edificio</h5>
                <div class="text-muted small">Desde aqui puedes bajar al detalle de cada sala y ajustar nombre o piso.</div>
            </div>
            <a href="/api/synced-rooms?buildingExternalId=@building.ExternalId" class="btn btn-secondary shadow-sm fw-semibold px-3" target="_blank">
                Ver API
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sala</th>
                        <th>Piso</th>
                        <th>Tipo</th>
                        <th>Equipos</th>
                        <th class="text-end">Accion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var room in Model.Rooms)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@room.EffectiveName</div>
                                <div class="small text-muted">@room.ExternalId</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">Piso @room.EffectiveFloor</span>
                                @if (!string.IsNullOrWhiteSpace(room.ManualName) || room.ManualFloor.HasValue)
                                {
                                    <span class="badge bg-warning text-dark ms-1">override</span>
                                }
                            </td>
                            <td>@room.Type</td>
                            <td>@room.DevicesCount</td>
                            <td class="text-end">
                                <a href="/admin/editsyncedroom/@room.ExternalId" class="btn btn-sm btn-outline-primary">
                                    Editar sala
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
