@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model SoteroMap.API.ViewModels.AdminLocationsViewModel
@{
    ViewData["Title"] = "Ubicaciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var requestScheme = string.IsNullOrWhiteSpace(Context?.Request?.Scheme) ? "http" : Context.Request.Scheme;
    var requestHost = Context?.Request?.Host.Host;
    var mapBaseUrl = !string.IsNullOrWhiteSpace(requestHost)
        ? $"{requestScheme}://{requestHost}:8080"
        : (Configuration["FrontendAppUrl"] ?? "http://localhost:8080");
    var totalPages = (int)Math.Ceiling((Model.TotalFilteredLocations <= 0 ? 1 : Model.TotalFilteredLocations) / (double)Model.PageSize);
    var currentPage = Math.Min(Model.Page, totalPages);
    var pageSizeOptions = new[] { 30, 50, 100, 200, 500 };
    var activeFilters = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Search))
    {
        activeFilters.Add($"Buscar edificio: {Model.Search}");
    }
    if (!string.IsNullOrWhiteSpace(Model.Campus))
    {
        activeFilters.Add($"Campus: {Model.Campus}");
    }
    if (!string.IsNullOrWhiteSpace(Model.Floor))
    {
        activeFilters.Add($"Piso: {Model.Floor}");
    }
    if (Context?.Request?.Query.ContainsKey("sortBy") == true && !string.IsNullOrWhiteSpace(Model.SortBy))
    {
        activeFilters.Add($"Orden: {Model.SortBy} ({(Model.SortDirection == "desc" ? "desc" : "asc")})");
    }
    if (Model.PageSize != 30)
    {
        activeFilters.Add($"Por pagina: {Model.PageSize}");
    }
    var hasActiveFilters = activeFilters.Count > 0;
    var isAdmin = User.IsInRole(SoteroMap.API.Models.AppRoles.Admin);
    string NextSortDirection(string column) => Model.SortBy == column && Model.SortDirection == "asc" ? "desc" : "asc";
    string SortArrow(string column) => Model.SortBy != column ? "bi bi-dash-lg" : (Model.SortDirection == "asc" ? "bi bi-chevron-down" : "bi bi-chevron-up");
    string SortUrl(string column) => Url.Action("Locations", new
    {
        search = Model.Search,
        campus = Model.Campus,
        floor = Model.Floor,
        sortBy = column,
        sortDirection = NextSortDirection(column),
        page = 1,
        pageSize = Model.PageSize
    }) ?? "/admin/locations";
    string PageUrl(int targetPage) => Url.Action("Locations", new
    {
        search = Model.Search,
        campus = Model.Campus,
        floor = Model.Floor,
        sortBy = Model.SortBy,
        sortDirection = Model.SortDirection,
        page = targetPage,
        pageSize = Model.PageSize
    }) ?? "/admin/locations";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Ubicaciones reales del frontend</h2>
        <div class="text-muted">Esta vista usa los edificios y salas sincronizados desde el mapa.</div>
    </div>
    <a href="/api/synced-buildings" class="btn btn-outline-secondary" target="_blank">
        <i class="bi bi-box-arrow-up-right me-1"></i> Ver API
    </a>
</div>

<style>
  .table-sort-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }

  .table-sort-link:hover {
    color: inherit;
    text-decoration: none;
  }

  .table-sort-link .sort-icon {
    font-size: 0.72rem;
    line-height: 1;
    flex: 0 0 auto;
  }
  .table-fixed-layout {
    table-layout: fixed;
    width: 100%;
  }

  .table-fixed-layout th,
  .table-fixed-layout td {
    white-space: normal;
    word-break: break-word;
    vertical-align: top;
  }
</style>

<script>
(() => {
  const bindSuggestions = (inputSelector, listId, endpoint) => {
    const input = document.querySelector(inputSelector);
    const list = document.getElementById(listId);
    if (!input || !list) {
      return;
    }

    let timer = null;
    input.addEventListener("input", () => {
      const query = input.value.trim();
      if (timer) {
        clearTimeout(timer);
      }

      timer = window.setTimeout(async () => {
        if (!query) {
          list.innerHTML = "";
          return;
        }

        try {
          const response = await fetch(`${endpoint}?query=${encodeURIComponent(query)}`, {
            headers: { "Accept": "application/json" },
          });
          if (!response.ok) {
            return;
          }

          const data = await response.json();
          list.innerHTML = "";
          (data || []).forEach((value) => {
            if (!value) return;
            const option = document.createElement("option");
            option.value = value;
            list.appendChild(option);
          });
        } catch (error) {
          console.warn("No se pudo cargar sugerencias de ubicaciones.", error);
        }
      }, 200);
    });
  };

  bindSuggestions('input[name="search"]', "locationSearchSuggestions", "/admin/suggestions/locations");
  bindSuggestions('input[name="campus"]', "campusSearchSuggestions", "/admin/suggestions/campus");
})();
</script>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-buildings text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Edificios</div>
                        <div class="fs-4 fw-bold">@Model.TotalBuildings</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-map text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Con mapa interior</div>
                        <div class="fs-4 fw-bold">@Model.BuildingsWithInteriorMap</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-door-open text-secondary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Salas sincronizadas</div>
                        <div class="fs-4 fw-bold">@Model.TotalRooms</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-pc-display text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Equipos asignados</div>
                        <div class="fs-4 fw-bold">@Model.AssignedInventoryItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4"> 
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4 position-relative js-autocomplete">
                <label class="form-label small fw-semibold">Buscar edificio</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       data-autocomplete-endpoint="/admin/suggestions/locations"
                       data-autocomplete-min="2"
                       class="form-control"
                       placeholder="nombre, ID, tipo, area..." />
                <div class="list-group position-absolute w-100 shadow-sm js-autocomplete-list" style="z-index: 1050; display: none;"></div>
            </div>
            <div class="col-md-6 position-relative js-autocomplete">
                <label class="form-label small fw-semibold">Campus</label>
                <input type="text"
                       name="campus"
                       value="@Model.Campus"
                       data-autocomplete-endpoint="/admin/suggestions/campus"
                       data-autocomplete-min="1"
                       class="form-control"
                       placeholder="ej: sotero" />
                <div class="list-group position-absolute w-100 shadow-sm js-autocomplete-list" style="z-index: 1050; display: none;"></div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Piso</label>
                <select name="floor" class="form-select">
                    <option value="">Todos</option>
                    <option value="0" selected="@(Model.Floor == "0")">Piso 0</option>
                    <option value="1" selected="@(Model.Floor == "1")">Piso 1</option>
                    <option value="2" selected="@(Model.Floor == "2")">Piso 2</option>
                    <option value="3" selected="@(Model.Floor == "3")">Piso 3</option>
                    <option value="4" selected="@(Model.Floor == "4")">Piso 4</option>
                    <option value="5" selected="@(Model.Floor == "5")">Piso 5</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Por pagina</label>
                <select name="pageSize" class="form-select js-page-size-select">
                    @foreach (var size in pageSizeOptions)
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </div>
            <div class="col-md-12">
                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary flex-grow-1">
                        <i class="bi bi-funnel me-1"></i> Filtrar
                    </button>
                    <a href="/admin/locations" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Limpiar filtros
                    </a>
                </div>
            </div>
        </form>
        <div class="mt-3">
            <div class="small text-muted mb-2">Filtros aplicados (@activeFilters.Count)</div>
            @if (hasActiveFilters)
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var filter in activeFilters)
                    {
                        <span class="badge rounded-pill text-bg-light border">@filter</span>
                    }
                </div>
            }
            else
            {
                <div class="small text-muted">Sin filtros adicionales aplicados.</div>
            }
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle table-fixed-layout">
                                                <thead class="table-light">
                    <tr>
                        <th><a href='@SortUrl("building")' class="table-sort-link"><span>Edificio</span><i class='@SortArrow("building") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("campus")' class="table-sort-link"><span>Campus</span><i class='@SortArrow("campus") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("type")' class="table-sort-link"><span>Tipo</span><i class='@SortArrow("type") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("floors")' class="table-sort-link"><span>Pisos</span><i class='@SortArrow("floors") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("rooms")' class="table-sort-link"><span>Salas</span><i class='@SortArrow("rooms") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("assigned")' class="table-sort-link"><span>Equipos asignados</span><i class='@SortArrow("assigned") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("suggested")' class="table-sort-link"><span>Sugeridos</span><i class='@SortArrow("suggested") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("map")' class="table-sort-link"><span>Estado mapa</span><i class='@SortArrow("map") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("coordinates")' class="table-sort-link"><span>Coordenadas</span><i class='@SortArrow("coordinates") sort-icon' aria-hidden="true"></i></a></th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loc in Model.Locations)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@loc.DisplayName</div>
                                <div class="small text-muted">@loc.ExternalId</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@loc.Campus</span>
                                @if (loc.HasManualOverride)
                                {
                                    <span class="badge bg-warning text-dark ms-1">override</span>
                                }
                            </td>
                            <td><span class="badge bg-info text-dark">@loc.Type</span></td>
                            <td class="small">@loc.AvailableFloors</td>
                            <td>@loc.RoomsCount</td>
                            <td>
                                <a href="/admin/inventory?assignment=assigned&buildingExternalId=@loc.ExternalId" class="badge bg-success text-decoration-none">
                                    @loc.AssignedInventoryCount equipos
                                </a>
                            </td>
                            <td>
                                <a href="/admin/inventory?assignment=suggested&buildingExternalId=@loc.ExternalId" class="badge bg-warning text-dark text-decoration-none">
                                    @loc.SuggestedInventoryCount sugeridos
                                </a>
                            </td>
                            <td class="small">
                                <div>@loc.MappingStatus</div>
                                <div class="text-muted">Inventario: @loc.InventoryStatus</div>
                            </td>
                            <td class="text-muted small">@loc.Coordinates</td>
                            <td class="text-end">
                                <a href="@($"{mapBaseUrl}/?id={Uri.EscapeDataString(loc.ExternalId)}&zoom=20&floor={loc.DefaultMapFloor}")"
                                   class="btn btn-sm btn-outline-info"
                                   target="sotero-map"
                                   onclick="window.open(this.href, 'sotero-map'); return false;"
                                   title="Ir al edificio en el mapa">
                                    <i class="bi bi-map"></i>
                                </a>
                                @if (isAdmin)
                                {
                                    <a href="/admin/editsyncedbuilding/@loc.ExternalId" class="btn btn-sm btn-outline-primary">
                                        Editar edificio
                                    </a>
                                }
                                <a href="/admin/activity?buildingExternalId=@loc.ExternalId" class="btn btn-sm btn-outline-secondary ms-2">
                                    Historial
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted small">
        Mostrando @Model.Locations.Count de @Model.TotalFilteredLocations edificio(s)
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary @(currentPage <= 1 ? "disabled" : null)"
           href="@PageUrl(currentPage - 1)">
            Anterior
        </a>
        <span class="btn btn-sm btn-light disabled">Pagina @currentPage de @totalPages</span>
        <a class="btn btn-sm btn-outline-secondary @(currentPage >= totalPages ? "disabled" : null)"
           href="@PageUrl(currentPage + 1)">
            Siguiente
        </a>
    </div>
</div>

<script>
window.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".js-page-size-select").forEach((select) => {
    select.addEventListener("change", () => {
      const form = select.closest("form");
      if (!form) {
        return;
      }

      if (typeof form.requestSubmit === "function") {
        form.requestSubmit();
      } else {
        form.submit();
      }
    });
  });

  const createDropdownItem = (text, isMuted = false) => {
    const item = document.createElement("button");
    item.type = "button";
    item.className = `list-group-item list-group-item-action${isMuted ? " text-muted" : ""}`;
    item.textContent = text;
    return item;
  };

  const bindSuggestions = (wrapper) => {
    const input = wrapper.querySelector("input[data-autocomplete-endpoint]");
    const list = wrapper.querySelector(".js-autocomplete-list");
    if (!input || !list) {
      return;
    }

    let timer = null;
    let controller = null;
    let activeIndex = -1;

    const getSelectableItems = () =>
      Array.from(list.querySelectorAll(".list-group-item")).filter((item) => !item.classList.contains("text-muted"));

    const updateActiveItem = () => {
      const items = getSelectableItems();
      items.forEach((item, index) => {
        item.classList.toggle("active", index === activeIndex);
      });

      if (activeIndex >= 0 && activeIndex < items.length) {
        items[activeIndex].scrollIntoView({ block: "nearest" });
      }
    };

    const submitForm = () => {
      const form = input.closest("form");
      if (form) {
        if (typeof form.requestSubmit === "function") {
          form.requestSubmit();
        } else {
          form.submit();
        }
      }
    };

    const hideList = () => {
      activeIndex = -1;
      list.style.display = "none";
      list.innerHTML = "";
    };

    const commitValue = (value) => {
      input.value = value;
      hideList();
      input.focus();
      submitForm();
    };

    const showLoading = () => {
      activeIndex = -1;
      list.innerHTML = "";
      list.appendChild(createDropdownItem("Cargando...", true));
      list.style.display = "block";
    };

    const showEmpty = () => {
      activeIndex = -1;
      list.innerHTML = "";
      list.appendChild(createDropdownItem("Sin resultados", true));
      list.style.display = "block";
    };

    input.addEventListener("input", () => {
      const query = input.value.trim();
      const minChars = Number(input.dataset.autocompleteMin || "1");

      if (timer) {
        clearTimeout(timer);
      }

      if (!query || query.length < minChars) {
        hideList();
        return;
      }

      showLoading();
      if (controller) {
        controller.abort();
      }
      controller = new AbortController();

      timer = window.setTimeout(async () => {
        try {
          const response = await fetch(`${input.dataset.autocompleteEndpoint}?query=${encodeURIComponent(query)}`, {
            headers: { "Accept": "application/json" },
            signal: controller.signal,
          });

          if (!response.ok) {
            showEmpty();
            return;
          }

          const data = await response.json();
          list.innerHTML = "";

          if (!data || data.length === 0) {
            showEmpty();
            return;
          }

          data.forEach((value) => {
            if (!value) return;
            const item = createDropdownItem(value);
            item.addEventListener("click", () => {
              commitValue(value);
            });
            list.appendChild(item);
          });

          activeIndex = -1;
          list.style.display = "block";
        } catch (error) {
          if (error.name === "AbortError") return;
          showEmpty();
          console.warn("No se pudo cargar sugerencias de ubicaciones.", error);
        }
      }, 220);
    });

    input.addEventListener("blur", () => {
      window.setTimeout(hideList, 150);
    });

    input.addEventListener("focus", () => {
      if (list.children.length > 0) {
        list.style.display = "block";
      }
    });

    input.addEventListener("keydown", (event) => {
      const items = getSelectableItems();
      const isListVisible = list.style.display !== "none" && items.length > 0;

      if (event.key === "ArrowDown") {
        if (!isListVisible) {
          return;
        }

        event.preventDefault();
        activeIndex = activeIndex < items.length - 1 ? activeIndex + 1 : 0;
        updateActiveItem();
        return;
      }

      if (event.key === "ArrowUp") {
        if (!isListVisible) {
          return;
        }

        event.preventDefault();
        activeIndex = activeIndex > 0 ? activeIndex - 1 : items.length - 1;
        updateActiveItem();
        return;
      }

      if (event.key === "Enter") {
        if (!isListVisible || activeIndex < 0 || activeIndex >= items.length) {
          return;
        }

        event.preventDefault();
        commitValue(items[activeIndex].textContent || "");
        return;
      }

      if (event.key === "Escape") {
        hideList();
      }
    });
  };

  document.querySelectorAll(".js-autocomplete").forEach(bindSuggestions);
});
</script>













