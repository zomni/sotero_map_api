@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model SoteroMap.API.ViewModels.AdminInventoryListViewModel
@{
    ViewData["Title"] = "Inventario";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = User.IsInRole(SoteroMap.API.Models.AppRoles.Admin);
    var requestScheme = string.IsNullOrWhiteSpace(Context?.Request?.Scheme) ? "http" : Context.Request.Scheme;
    var requestHost = Context?.Request?.Host.Host;
    var mapBaseUrl = !string.IsNullOrWhiteSpace(requestHost)
        ? $"{requestScheme}://{requestHost}:8080"
        : (Configuration["FrontendAppUrl"] ?? "http://localhost:8080");
    var totalPages = (int)Math.Ceiling((Model.TotalFilteredItems <= 0 ? 1 : Model.TotalFilteredItems) / (double)Model.PageSize);
    var currentPage = Math.Min(Model.Page, totalPages);
    var pageSizeOptions = new[] { 30, 50, 100, 200, 500 };
    var isInconsistencyView = Model.AssignmentFilter == "inconsistent" || Model.OnlyInconsistencies;
    var legacyOnlyInconsistencies = Model.OnlyInconsistencies && Model.AssignmentFilter != "inconsistent";
    var activeFilters = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Search))
    {
        activeFilters.Add($"Buscar: {Model.Search}");
    }
    if (!string.IsNullOrWhiteSpace(Model.Category))
    {
        activeFilters.Add($"Categoria: {Model.Category}");
    }
    if (!string.IsNullOrWhiteSpace(Model.Status))
    {
        activeFilters.Add($"Estado: {Model.Status}");
    }
    if (!string.IsNullOrWhiteSpace(Model.AssignmentFilter) && Model.AssignmentFilter != "all")
    {
        var assignmentLabel = Model.AssignmentFilter switch
        {
            "pending" => "Pendientes",
            "assigned" => "Asignados",
            "suggested" => "Con sugerencia",
            "inconsistent" => "Con incongruencias",
            _ => Model.AssignmentFilter
        };
        activeFilters.Add($"Asignacion: {assignmentLabel}");
    }
    if (!string.IsNullOrWhiteSpace(Model.BuildingExternalId))
    {
        var selectedBuilding = Model.Buildings.FirstOrDefault(building => building.ExternalId == Model.BuildingExternalId);
        activeFilters.Add($"Edificio: {(selectedBuilding?.EffectiveDisplayName ?? Model.BuildingExternalId)}");
    }
    if (!string.IsNullOrWhiteSpace(Model.InconsistencyType))
    {
        var inconsistencyLabel = Model.AvailableInconsistencyTypes.FirstOrDefault(option => option.Value == Model.InconsistencyType)?.Label ?? Model.InconsistencyType;
        activeFilters.Add($"Tipo de incongruencia: {inconsistencyLabel}");
    }
    if (Context?.Request?.Query.ContainsKey("sortBy") == true && !string.IsNullOrWhiteSpace(Model.SortBy))
    {
        activeFilters.Add($"Orden: {Model.SortBy} ({(Model.SortDirection == "desc" ? "desc" : "asc")})");
    }
    if (Model.PageSize != 30)
    {
        activeFilters.Add($"Por pagina: {Model.PageSize}");
    }
    var hasActiveFilters = activeFilters.Count > 0;
    var buildingFloorLookup = Model.Buildings.ToDictionary(
        building => building.ExternalId,
        building =>
        {
            var effectiveFloors = (building.EffectiveFloorsJson ?? string.Empty)
                .Replace("[", string.Empty)
                .Replace("]", string.Empty)
                .Replace("\"", string.Empty)
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .FirstOrDefault();

            return int.TryParse(effectiveFloors, out var parsedFloor) ? parsedFloor : 0;
        });
    var reviewInconsistenciesUrl = Url.Action("Inventory", new
    {
        search = Model.Search,
        category = Model.Category,
        status = Model.Status,
        assignment = "inconsistent",
        buildingExternalId = Model.BuildingExternalId,
        sortBy = Model.SortBy,
        sortDirection = Model.SortDirection,
        inconsistencyType = Model.InconsistencyType,
        onlyInconsistencies = false,
        page = 1,
        pageSize = Model.PageSize
    }) ?? "/admin/inventory?assignment=inconsistent";
    var fullInventoryUrl = Url.Action("Inventory", new
    {
        search = Model.Search,
        category = Model.Category,
        status = Model.Status,
        assignment = "all",
        buildingExternalId = Model.BuildingExternalId,
        sortBy = Model.SortBy,
        sortDirection = Model.SortDirection,
        inconsistencyType = Model.InconsistencyType,
        onlyInconsistencies = false,
        page = 1,
        pageSize = Model.PageSize
    }) ?? "/admin/inventory";
    var currentInventoryUrl = $"{Context?.Request?.Path}{Context?.Request?.QueryString}";
    string NextSortDirection(string column) => Model.SortBy == column && Model.SortDirection == "asc" ? "desc" : "asc";
    string SortArrow(string column) => Model.SortBy != column ? "bi bi-dash-lg" : (Model.SortDirection == "asc" ? "bi bi-chevron-down" : "bi bi-chevron-up");
    string SortUrl(string column) => Url.Action("Inventory", new
    {
        search = Model.Search,
        category = Model.Category,
        status = Model.Status,
        assignment = Model.AssignmentFilter,
        buildingExternalId = Model.BuildingExternalId,
        sortBy = column,
        sortDirection = NextSortDirection(column),
        inconsistencyType = Model.InconsistencyType,
        onlyInconsistencies = legacyOnlyInconsistencies,
        page = 1,
        pageSize = Model.PageSize
    }) ?? "/admin/inventory";
    string PageUrl(int targetPage) => Url.Action("Inventory", new
    {
        search = Model.Search,
        category = Model.Category,
        status = Model.Status,
        assignment = Model.AssignmentFilter,
        buildingExternalId = Model.BuildingExternalId,
        sortBy = Model.SortBy,
        sortDirection = Model.SortDirection,
        inconsistencyType = Model.InconsistencyType,
        onlyInconsistencies = legacyOnlyInconsistencies,
        page = targetPage,
        pageSize = Model.PageSize
    }) ?? "/admin/inventory";
    string InconsistencyTypeUrl(string value) => Url.Action("Inventory", new
    {
        search = Model.Search,
        category = Model.Category,
        status = Model.Status,
        assignment = Model.AssignmentFilter,
        buildingExternalId = Model.BuildingExternalId,
        sortBy = Model.SortBy,
        sortDirection = Model.SortDirection,
        inconsistencyType = value,
        onlyInconsistencies = legacyOnlyInconsistencies,
        page = 1,
        pageSize = Model.PageSize
    }) ?? "/admin/inventory";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Inventario importado</h2>
        <div class="text-muted">Los equipos viven en el backend. El mapa y las salas siguen viniendo del frontend.</div>
    </div>
    <div class="d-flex gap-2">
        @if (isAdmin)
        {
            <a href="/admin/inventory/create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Agregar equipo
            </a>
        }
        <a href="/api/inventory-import/status" class="btn btn-outline-secondary" target="_blank">
            <i class="bi bi-activity me-1"></i> Estado importacion
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<style>
  .table-sort-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }

  .table-sort-link:hover {
    color: inherit;
    text-decoration: none;
  }

  .table-sort-link .sort-icon {
    font-size: 0.72rem;
    line-height: 1;
    flex: 0 0 auto;
  }

  .table-sort-button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--bs-dark);
    font-weight: 600;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .table-sort-button:hover,
  .table-sort-button:focus {
    color: var(--bs-dark);
    box-shadow: none;
  }
  .table-fixed-layout {
    table-layout: fixed;
    width: 100%;
  }

  .table-fixed-layout th,
  .table-fixed-layout td {
    white-space: normal;
    word-break: break-word;
    vertical-align: top;
  }
</style>


<div class="row g-3 mb-4">
    <div class="col-xl col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-pc-display text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total</div>
                        <div class="fs-4 fw-bold">@Model.TotalItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-check2-circle text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Asignados</div>
                        <div class="fs-4 fw-bold">@Model.AssignedItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Pendientes</div>
                        <div class="fs-4 fw-bold">@Model.PendingItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-lightbulb text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Con sugerencia</div>
                        <div class="fs-4 fw-bold">@Model.SuggestedItems</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl col-md-12">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Con incongruencias</div>
                        <div class="fs-4 fw-bold">@Model.InconsistentItems</div>
                    </div>
                </div>
                <div>
                    @if (isInconsistencyView)
                    {
                        <a href="@fullInventoryUrl"
                           class="btn btn-outline-secondary"
                           title="Ver todo el inventario"
                           aria-label="Ver todo el inventario">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    }
                    else if (Model.InconsistentItems > 0)
                    {
                        <a href="@reviewInconsistenciesUrl"
                           class="btn btn-outline-danger"
                           title="Revisar incongruencias"
                           aria-label="Revisar incongruencias">
                            <i class="bi bi-search"></i>
                        </a>
                    }
                    else
                    {
                        <span class="btn btn-outline-secondary disabled" title="Sin incongruencias detectadas" aria-hidden="true">
                            <i class="bi bi-check2-circle"></i>
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" action="/admin/inventory" class="row g-3 align-items-end">
            <div class="col-lg-3 position-relative js-autocomplete">
                <label class="form-label">Buscar</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       data-autocomplete-endpoint="/admin/suggestions/inventory"
                       data-autocomplete-min="2"
                       class="form-control"
                       placeholder="S/N, descripcion, usuario, IP..." />
                <div class="list-group position-absolute w-100 shadow-sm js-autocomplete-list" style="z-index: 1050; display: none;"></div>
            </div>
            <div class="col-lg-2">
                <label class="form-label">Categoria</label>
                <select name="category" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var option in Model.Categories)
                    {
                        <option value="@option" selected="@(Model.Category == option)">@option</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <label class="form-label">Estado</label>
                <select name="status" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var option in Model.Statuses)
                    {
                        <option value="@option" selected="@(Model.Status == option)">@option</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <label class="form-label">Asignacion</label>
                <select name="assignment" class="form-select">
                    <option value="pending" selected="@(Model.AssignmentFilter == "pending")">Pendientes</option>
                    <option value="assigned" selected="@(Model.AssignmentFilter == "assigned")">Asignados</option>
                    <option value="suggested" selected="@(Model.AssignmentFilter == "suggested")">Con sugerencia</option>
                    <option value="inconsistent" selected="@(Model.AssignmentFilter == "inconsistent" || (Model.AssignmentFilter == "all" && isInconsistencyView))">Con incongruencias</option>
                    <option value="all" selected="@(Model.AssignmentFilter == "all" && !isInconsistencyView)">Todos</option>
                </select>
            </div>
            <div class="col-lg-3">
                <label class="form-label">Edificio asignado</label>
                <select name="buildingExternalId" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var building in Model.Buildings)
                    {
                        <option value="@building.ExternalId" selected="@(Model.BuildingExternalId == building.ExternalId)">
                            @building.EffectiveDisplayName
                        </option>
                    }
                </select>
            </div>
            <div class="col-lg-auto">
                <label class="form-label">Por pagina</label>
                <select name="pageSize" class="form-select w-auto js-page-size-select" style="min-width: 88px;">
                    @foreach (var size in pageSizeOptions)
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                </select>
            </div>
            <div class="col-lg-8">
                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                <input type="hidden" name="inconsistencyType" value="@Model.InconsistencyType" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary flex-grow-1">
                        <i class="bi bi-funnel me-1"></i> Filtrar
                    </button>
                    <a href="/admin/inventory" class="btn btn-secondary" title="Limpiar filtros" aria-label="Limpiar filtros">
                        <i class="bi bi-x-circle"></i>
                    </a>
                </div>
            </div>
        </form>
        <div class="mt-3">
            <div class="small text-muted mb-2">Filtros aplicados (@activeFilters.Count)</div>
            @if (hasActiveFilters)
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var filter in activeFilters)
                    {
                        <span class="badge rounded-pill text-bg-light border">@filter</span>
                    }
                </div>
            }
            else
            {
                <div class="small text-muted">Sin filtros adicionales aplicados.</div>
            }
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle table-fixed-layout">
                                                <thead class="table-light">
                    <tr>
                        <th><a href='@SortUrl("row")' class="table-sort-link"><span>Fila</span><i class='@SortArrow("row") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("equipment")' class="table-sort-link"><span>Equipo</span><i class='@SortArrow("equipment") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("unit")' class="table-sort-link"><span>Unidad</span><i class='@SortArrow("unit") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("user")' class="table-sort-link"><span>Usuario</span><i class='@SortArrow("user") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("ip")' class="table-sort-link"><span>IP</span><i class='@SortArrow("ip") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("category")' class="table-sort-link"><span>Categoria</span><i class='@SortArrow("category") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("status")' class="table-sort-link"><span>Estado</span><i class='@SortArrow("status") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("suggestion")' class="table-sort-link"><span>Sugerencia</span><i class='@SortArrow("suggestion") sort-icon' aria-hidden="true"></i></a></th>
                        <th><a href='@SortUrl("assignment")' class="table-sort-link"><span>Asignacion</span><i class='@SortArrow("assignment") sort-icon' aria-hidden="true"></i></a></th>
                        <th>
                            <div class="dropdown">
                                <button class="table-sort-button dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Incongruencias
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @foreach (var option in Model.AvailableInconsistencyTypes)
                                    {
                                        <li>
                                            <a class="dropdown-item @(Model.InconsistencyType == option.Value ? "active" : null)" href="@InconsistencyTypeUrl(option.Value)">
                                                @option.Label
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-muted small">
                                <div>#@item.Id</div>
                                <div class="text-muted">origen: @item.RowNumber</div>
                            </td>
                            <td>
                                <div class="fw-semibold">S/N: @(string.IsNullOrWhiteSpace(item.SerialNumber) ? "Sin S/N" : item.SerialNumber)</div>
                                <div class="small text-muted">@item.Description</div>
                                <div class="small text-muted">Item @item.ItemNumber</div>
                                <div class="small text-muted">@item.SourceFile</div>
                            </td>
                            <td class="small">
                                <div>@item.UnitOrDepartment</div>
                                <div class="text-muted">@item.OrganizationalUnit</div>
                            </td>
                            <td class="small">
                                <div>@item.ResponsibleUser</div>
                                <div class="text-muted">@item.Email</div>
                            </td>
                            <td class="small font-monospace">@item.IpAddress</td>
                            <td><span class="badge bg-secondary">@item.InferredCategory</span></td>
                            <td>
                                @{
                                    var badgeClass = item.InferredStatus switch
                                    {
                                        "active" => "bg-success",
                                        "stolen" => "bg-danger",
                                        _ => "bg-warning text-dark"
                                    };
                                }
                                <span class="badge @badgeClass">@item.InferredStatus</span>
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrWhiteSpace(item.AssignedBuildingExternalId))
                                {
                                }
                                else if (string.IsNullOrWhiteSpace(item.MatchedBuildingExternalId))
                                {
                                    <span class="text-muted">Sin sugerencia</span>
                                }
                                else
                                {
                                    <div>@item.MatchedBuildingExternalId</div>
                                    @if (!string.IsNullOrWhiteSpace(item.MatchedRoomExternalId))
                                    {
                                        <div class="text-muted">@item.MatchedRoomExternalId</div>
                                    }
                                    <div class="text-muted">@item.MatchConfidence</div>
                                }
                            </td>
                            <td class="small">
                                @if (string.IsNullOrWhiteSpace(item.AssignedBuildingExternalId))
                                {
                                    <span class="text-muted">Pendiente</span>
                                }
                                else
                                {
                                    <div>@item.AssignedBuildingExternalId</div>
                                    @if (!string.IsNullOrWhiteSpace(item.AssignedRoomExternalId))
                                    {
                                        <div class="text-muted">@item.AssignedRoomExternalId</div>
                                    }
                                    @if (item.AssignedFloor.HasValue)
                                    {
                                        <div class="text-muted">Piso @item.AssignedFloor</div>
                                    }
                                }
                            </td>
                            <td class="small">
                                @if (Model.InconsistencySummaries.TryGetValue(item.Id, out var inconsistencySummary))
                                {
                                    var detailUrl = Url.Action("InventoryInconsistency", new { id = item.Id, returnUrl = currentInventoryUrl })
                                        ?? $"/admin/inventory/inconsistency/{item.Id}";
                                    <a href="@detailUrl" class="btn btn-sm btn-outline-danger mb-2">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>Revisar
                                    </a>
                                    <div class="text-muted">@inconsistencySummary</div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-end flex-nowrap align-items-center">
                                    @if (!string.IsNullOrWhiteSpace(item.AssignedBuildingExternalId))
                                    {
                                        var resolvedFloor = item.AssignedFloor
                                            ?? buildingFloorLookup.GetValueOrDefault(item.AssignedBuildingExternalId, 0);
                                        var deviceKey = !string.IsNullOrWhiteSpace(item.SerialNumber)
                                            ? item.SerialNumber
                                            : (!string.IsNullOrWhiteSpace(item.ItemNumber)
                                                ? item.ItemNumber
                                                : $"inventory-{item.Id}");
                                        var inventoryMapUrl = $"{mapBaseUrl}/?id={Uri.EscapeDataString(item.AssignedBuildingExternalId)}&zoom=20&floor={resolvedFloor}&view=devices&deviceKey={Uri.EscapeDataString(deviceKey)}";

                                        <a href="@inventoryMapUrl"
                                           class="btn btn-sm btn-outline-info"
                                           target="sotero-map"
                                           onclick="window.open(this.href, 'sotero-map'); return false;"
                                           title="Ir al edificio en el mapa">
                                            <i class="bi bi-map"></i>
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.DeliveryFormPdfFileName))
                                    {
                                        <a href="/admin/inventory/@item.Id/form-pdf"
                                           class="btn btn-sm btn-outline-danger"
                                           target="_blank"
                                           title="Ver formulario PDF"
                                           aria-label="Ver formulario PDF">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                    }
                                    <a href="/admin/editinventoryitem/@item.Id" class="btn btn-sm btn-outline-primary text-nowrap">
                                        @(isAdmin ? "Editar" : "Ver")
                                    </a>
                                    @if (isAdmin)
                                    {
                                        <form method="post"
                                              action="/admin/deleteinventoryitem/@item.Id"
                                              class="d-inline"
                                              onsubmit="return confirm('Estas seguro de eliminar este equipo?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar equipo">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted small">
        Mostrando @Model.Items.Count de @Model.TotalFilteredItems resultado(s)
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary @(currentPage <= 1 ? "disabled" : null)"
           href="@PageUrl(currentPage - 1)">
            Anterior
        </a>
        <span class="btn btn-sm btn-light disabled">Pagina @currentPage de @totalPages</span>
        <a class="btn btn-sm btn-outline-secondary @(currentPage >= totalPages ? "disabled" : null)"
           href="@PageUrl(currentPage + 1)">
            Siguiente
        </a>
    </div>
</div>

<script>
window.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".js-page-size-select").forEach((select) => {
    select.addEventListener("change", () => {
      const form = select.closest("form");
      if (!form) {
        return;
      }

      if (typeof form.requestSubmit === "function") {
        form.requestSubmit();
      } else {
        form.submit();
      }
    });
  });

  const createDropdownItem = (text, isMuted = false) => {
    const item = document.createElement("button");
    item.type = "button";
    item.className = `list-group-item list-group-item-action${isMuted ? " text-muted" : ""}`;
    item.textContent = text;
    return item;
  };

  const bindSuggestions = (wrapper) => {
    const input = wrapper.querySelector("input[data-autocomplete-endpoint]");
    const list = wrapper.querySelector(".js-autocomplete-list");
    if (!input || !list) {
      return;
    }

    let timer = null;
    let controller = null;
    let activeIndex = -1;

    const getSelectableItems = () =>
      Array.from(list.querySelectorAll(".list-group-item")).filter((item) => !item.classList.contains("text-muted"));

    const updateActiveItem = () => {
      const items = getSelectableItems();
      items.forEach((item, index) => {
        item.classList.toggle("active", index === activeIndex);
      });

      if (activeIndex >= 0 && activeIndex < items.length) {
        items[activeIndex].scrollIntoView({ block: "nearest" });
      }
    };

    const submitForm = () => {
      const form = input.closest("form");
      if (form) {
        if (typeof form.requestSubmit === "function") {
          form.requestSubmit();
        } else {
          form.submit();
        }
      }
    };

    const hideList = () => {
      activeIndex = -1;
      list.style.display = "none";
      list.innerHTML = "";
    };

    const commitValue = (value) => {
      input.value = value;
      hideList();
      input.focus();
      submitForm();
    };

    const showLoading = () => {
      activeIndex = -1;
      list.innerHTML = "";
      list.appendChild(createDropdownItem("Cargando...", true));
      list.style.display = "block";
    };

    const showEmpty = () => {
      activeIndex = -1;
      list.innerHTML = "";
      list.appendChild(createDropdownItem("Sin resultados", true));
      list.style.display = "block";
    };

    input.addEventListener("input", () => {
      const query = input.value.trim();
      const minChars = Number(input.dataset.autocompleteMin || "1");

      if (timer) {
        clearTimeout(timer);
      }

      if (!query || query.length < minChars) {
        hideList();
        return;
      }

      showLoading();
      if (controller) {
        controller.abort();
      }
      controller = new AbortController();

      timer = window.setTimeout(async () => {
        try {
          const response = await fetch(`${input.dataset.autocompleteEndpoint}?query=${encodeURIComponent(query)}`, {
            headers: { "Accept": "application/json" },
            signal: controller.signal,
          });

          if (!response.ok) {
            showEmpty();
            return;
          }

          const data = await response.json();
          list.innerHTML = "";

          if (!data || data.length === 0) {
            showEmpty();
            return;
          }

          data.forEach((value) => {
            if (!value) return;
            const item = createDropdownItem(value);
            item.addEventListener("click", () => {
              commitValue(value);
            });
            list.appendChild(item);
          });

          activeIndex = -1;
          list.style.display = "block";
        } catch (error) {
          if (error.name === "AbortError") return;
          showEmpty();
          console.warn("No se pudo cargar sugerencias del inventario.", error);
        }
      }, 220);
    });

    input.addEventListener("blur", () => {
      window.setTimeout(hideList, 150);
    });

    input.addEventListener("focus", () => {
      if (list.children.length > 0) {
        list.style.display = "block";
      }
    });

    input.addEventListener("keydown", (event) => {
      const items = getSelectableItems();
      const isListVisible = list.style.display !== "none" && items.length > 0;

      if (event.key === "ArrowDown") {
        if (!isListVisible) {
          return;
        }

        event.preventDefault();
        activeIndex = activeIndex < items.length - 1 ? activeIndex + 1 : 0;
        updateActiveItem();
        return;
      }

      if (event.key === "ArrowUp") {
        if (!isListVisible) {
          return;
        }

        event.preventDefault();
        activeIndex = activeIndex > 0 ? activeIndex - 1 : items.length - 1;
        updateActiveItem();
        return;
      }

      if (event.key === "Enter") {
        if (!isListVisible || activeIndex < 0 || activeIndex >= items.length) {
          return;
        }

        event.preventDefault();
        commitValue(items[activeIndex].textContent || "");
        return;
      }

      if (event.key === "Escape") {
        hideList();
      }
    });
  };

  document.querySelectorAll(".js-autocomplete").forEach(bindSuggestions);
});
</script>
















